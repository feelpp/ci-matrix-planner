[
  {
    "name": "defaults (components mode)",
    "config": {
      "jobs": ["feelpp", "testsuite", "toolboxes", "mor", "python"],
      "targets": ["ubuntu:24.04", "ubuntu:22.04", "debian:13", "debian:12", "fedora:42"],
      "defaults": { "mode": "components" }
    },
    "message": "",
    "labels": [],
    "expected": {
      "mode": "components",
      "enabledJobs": ["feelpp", "testsuite", "toolboxes", "mor", "python"],
      "targetsList": "ubuntu:24.04 ubuntu:22.04 debian:13 debian:12 fedora:42"
    }
  },
  {
    "name": "only=feelpp targets=fedora:42",
    "config": {},
    "message": "only=feelpp\ntargets=fedora:42",
    "labels": [],
    "expected": {
      "enabledJobs": ["feelpp"],
      "targetsList": "fedora:42"
    }
  },
  {
    "name": "only=feelpp,toolboxes targets=fedora:42,debian:13",
    "config": {},
    "message": "only=feelpp,toolboxes\ntargets=fedora:42,debian:13",
    "labels": [],
    "expected": {
      "enabledJobs": ["feelpp","toolboxes"],
      "targetsList": "fedora:42 debian:13"
    }
  },
  {
    "name": "mode full becomes single job (old schema)",
    "config": { "fullBuild": { "job": "feelpp-spack" } },
    "message": "mode=full",
    "labels": [],
    "expected": {
      "mode": "full",
      "enabledJobs": ["feelpp-spack"]
    }
  },
  {
    "name": "include and exclude",
    "config": { "targets": ["ubuntu:22.04"] },
    "message": "include=debian:12\ndelete=ignored\nexclude=ubuntu:22.04",
    "labels": [],
    "expected": {
      "targetsList": "debian:12"
    }
  },
  {
    "name": "auto-detect full mode from only=feelpp-full",
    "config": {
      "jobs": ["feelpp", "testsuite", "toolboxes", "mor", "python"],
      "fullBuild": { "job": "feelpp-full" }
    },
    "message": "only=feelpp-full",
    "labels": [],
    "expected": {
      "mode": "full",
      "enabledJobs": ["feelpp-full"]
    }
  },
  {
    "name": "new modes schema with multiple full jobs",
    "config": {
      "jobs": ["feelpp", "testsuite", "toolboxes"],
      "modes": {
        "full": {
          "jobs": ["feelpp-full", "feelpp-full-debug"],
          "targets": ["ubuntu:24.04"]
        }
      }
    },
    "message": "mode=full",
    "labels": [],
    "expected": {
      "mode": "full",
      "enabledJobs": ["feelpp-full", "feelpp-full-debug"],
      "targetsList": "ubuntu:24.04"
    }
  },
  {
    "name": "mode=full with only= filter",
    "config": {
      "modes": {
        "full": {
          "jobs": ["feelpp-full", "feelpp-full-debug"]
        }
      }
    },
    "message": "mode=full\nonly=feelpp-full",
    "labels": [],
    "expected": {
      "mode": "full",
      "enabledJobs": ["feelpp-full"]
    }
  },
  {
    "name": "fullBuild.jobs array (backwards compat)",
    "config": {
      "fullBuild": { "jobs": ["feelpp-full", "feelpp-full-alt"] }
    },
    "message": "mode=full",
    "labels": [],
    "expected": {
      "mode": "full",
      "enabledJobs": ["feelpp-full", "feelpp-full-alt"]
    }
  },
  {
    "name": "full mode with mode-specific targets",
    "config": {
      "targets": ["ubuntu:24.04", "debian:13", "fedora:42"],
      "defaults": { "targets": ["ubuntu:24.04", "debian:13", "fedora:42"] },
      "fullBuild": {
        "job": "feelpp-full",
        "targets": ["ubuntu:24.04"]
      }
    },
    "message": "mode=full",
    "labels": [],
    "expected": {
      "mode": "full",
      "enabledJobs": ["feelpp-full"],
      "targetsList": "ubuntu:24.04"
    }
  },
  {
    "name": "ci-mode-full label triggers full mode",
    "config": {
      "fullBuild": { "job": "feelpp-full" }
    },
    "message": "",
    "labels": ["ci-mode-full"],
    "expected": {
      "mode": "full",
      "enabledJobs": ["feelpp-full"]
    }
  }
]
