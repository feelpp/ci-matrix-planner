  {
    "name": "images profile defaults become primary matrix",
    "profile": "images",
    "config": {
      "profiles": {
        "images": {
          "jobs": ["images"],
          "defaults": {
            "targets": ["ubuntu:noble"]
          },
          "catalog": {
            "ubuntu:noble": {
              "flavor": "ubuntu",
              "dist": "noble",
              "version": "24.04",
              "docker": true,
              "oci_dist": "ubuntu-24.04",
              "image_backend": "apt",
              "image_strategy": "components",
              "component_set": "default",
              "base_image": "ubuntu:24.04"
            },
            "spack:openmpi": {
              "flavor": "spack",
              "dist": "openmpi",
              "version": "latest",
              "docker": true,
              "oci_dist": "spack-openmpi",
              "image_backend": "spack",
              "image_strategy": "full",
              "spack_environment": "cpu/openmpi",
              "base_image": "ubuntu:24.04"
            }
          },
          "groups": {
            "ubuntu": ["ubuntu:noble"],
            "spack": ["spack:openmpi"]
          }
        }
      }
    },
    "message": "",
    "labels": [],
    "expected": {
      "profile": "images",
      "mode": "images",
      "enabledJobs": ["images"],
      "enabledProfiles": ["images"],
      "pkgEnabled": false,
      "targetsList": "ubuntu:noble",
      "matrixIncludeLen": 1
    }
  },
